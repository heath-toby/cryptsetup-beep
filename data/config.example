# /etc/cryptsetup-beep/config — generated by `cryptsetup-beep --init`.
# This file is sourced as POSIX shell. Do not include unquoted spaces in
# values; quote anything containing whitespace or special characters.

# How to make a sound: `alsa` (any ALSA card) or `pcspkr` (PC speaker via beep(1))
METHOD=alsa

# ALSA-only options ----------------------------------------------------------

# Substring searched for in /proc/asound/card*/codec* to find the right card
# at boot time. Case-insensitive. Leave empty to play to whichever card the
# kernel registered first.
CODEC_MATCH=SN6140

# Whitespace-separated list of kernel modules to modprobe in the initramfs
# before the card can register. Determined by the wizard from `lsmod` on the
# live system at the moment you ran `cryptsetup-beep --init`.
CODEC_MODULES="snd_hda_intel snd_hda_codec_conexant snd_hda_codec_generic"

# PCM device index on the chosen card (almost always 0 for analog output).
PCM_DEVICE=0

# ALSA mixer values applied before playing. Each is "<percent>,<state>" where
# state is "on" or "off". Leave a variable blank to skip that control.
MIXER_MASTER="82%,on"
MIXER_SPEAKER="100%,on"
MIXER_HEADPHONE="70%,on"
MIXER_PCM="100%"

# Path to the WAV file to play. cryptsetup-beep picks one of the four below
# based on which prompt systemd-cryptsetup is showing — the initial
# passphrase prompt, a passphrase retry, an initial token PIN prompt, or a
# token PIN retry. Any path you leave undefined falls back to BEEP_WAV.
BEEP_WAV=/usr/share/cryptsetup-beep/beep.wav
BEEP_WAV_READY=/usr/share/cryptsetup-beep/beep.wav
BEEP_WAV_RETRY=/usr/share/cryptsetup-beep/beep-retry.wav
BEEP_WAV_PIN=/usr/share/cryptsetup-beep/beep-pin.wav
BEEP_WAV_PIN_RETRY=/usr/share/cryptsetup-beep/beep-pin-retry.wav

# PC speaker options ---------------------------------------------------------

# Frequency in Hz and length in milliseconds, passed to beep(1). The PIN
# tone uses PCSPKR_FREQ_PIN (one octave above PCSPKR_FREQ by default), and
# retry prompts repeat the beep twice.
PCSPKR_FREQ=440
PCSPKR_FREQ_PIN=880
PCSPKR_LEN=500
